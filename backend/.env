# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database
MONGODB_URI=mongodb://localhost:27017/chatbot-platform

# Redis (for queues & caching)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LINE_CHANNEL_SECRET=your-line-channel-secret

# Facebook Messenger API
FB_PAGE_ACCESS_TOKEN=your-fb-page-access-token
FB_APP_SECRET=your-fb-app-secret
FB_VERIFY_TOKEN=your-fb-verify-token

# File Upload (optional, for images in flows)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
